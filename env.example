'use strict';

const state = { folder: 'inbox', query: '', messages: [], current: null };
const $ = (id) => document.getElementById(id);

function toast(message) {
  const el = $('toast');
  el.textContent = message;
  el.classList.add('show');
  setTimeout(() => el.classList.remove('show'), 2800);
}

async function api(url, options = {}) {
  const response = await fetch(url, {
    headers: { 'Content-Type': 'application/json', ...(options.headers || {}) },
    ...options
  });
  const data = await response.json().catch(() => ({}));
  if (!response.ok) throw new Error(data.error || `Request failed (${response.status})`);
  return data;
}

function displayName(value) {
  return (value || '').replace(/<[^>]+>/g, '').replace(/^"|"$/g, '').trim() || '(unknown)';
}

function formatDate(value) {
  const d = new Date(value);
  if (Number.isNaN(d.getTime())) return '';
  const now = new Date();
  return d.toDateString() === now.toDateString()
    ? d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
    : d.toLocaleDateString([], { month: 'short', day: 'numeric' });
}

function renderMessages() {
  const list = $('message-list');
  $('reader').classList.add('hidden');
  list.classList.remove('hidden');
  if (!state.messages.length) {
    list.innerHTML = '<div class="empty">No messages found.</div>';
    return;
  }
  list.innerHTML = state.messages.map((m) => {
    const unread = (m.labelIds || []).includes('UNREAD');
    const starred = (m.labelIds || []).includes('STARRED');
    const who = state.folder === 'sent' ? m.to : m.from;
    return `<div class="message-row ${unread ? 'unread' : ''}" data-id="${m.id}">
      <button class="star-button ${starred ? 'starred' : ''}" data-star-id="${m.id}" data-starred="${starred}">${starred ? '★' : '☆'}</button>
      <div>${escapeHtml(displayName(who))}</div>
      <div class="message-subject">${escapeHtml(m.subject)} <span class="snippet">- ${escapeHtml(m.snippet || '')}</span></div>
      <div class="message-date">${formatDate(m.internalDate)}</div>
    </div>`;
  }).join('');
}

function escapeHtml(value) {
  return String(value || '').replace(/[&<>'"]/g, (ch) => ({ '&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;' }[ch]));
}

async function loadMessages() {
  $('status').textContent = 'Loading…';
  try {
    const params = new URLSearchParams({ folder: state.folder });
    if (state.query) params.set('q', state.query);
    const data = await api(`/api/messages?${params}`);
    state.messages = data.messages || [];
    renderMessages();
    $('status').textContent = `${state.messages.length} messages`;
  } catch (error) {
    $('status').textContent = '';
    toast(error.message);
  }
}

async function openMessage(id) {
  try {
    const message = await api(`/api/messages/${id}`);
    state.current = message;
    $('message-list').classList.add('hidden');
    $('reader').classList.remove('hidden');
    $('reader-subject').textContent = message.subject;
    $('reader-from').textContent = message.from;
    $('reader-date').textContent = message.date;
    $('reader-to').textContent = `to ${message.to}`;
    $('reader-body').textContent = message.text || message.snippet || '(HTML-only message; plain text preview unavailable.)';
  } catch (error) { toast(error.message); }
}

function openCompose(prefill = {}) {
  $('compose-to').value = prefill.to || '';
  $('compose-subject').value = prefill.subject || '';
  $('compose-body').value = prefill.body || '';
  $('compose-modal').classList.remove('hidden');
  $('compose-to').focus();
}

async function init() {
  try {
    const config = await api('/api/config');
    $('allowed-email').textContent = config.allowedEmail;
    if (!config.signedIn) {
      $('login').classList.remove('hidden');
      if (!config.oauthConfigured) $('oauth-warning').classList.remove('hidden');
      return;
    }
    $('app').classList.remove('hidden');
    $('profile-name').textContent = config.user.name;
    $('profile-email').textContent = config.user.email;
    $('avatar').src = config.user.picture || 'data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64"><rect width="100%" height="100%" fill="%23c5221f"/><text x="50%" y="58%" dominant-baseline="middle" text-anchor="middle" font-family="Arial" font-size="30" fill="white">A</text></svg>';
    await loadMessages();
  } catch (error) { toast(error.message); }
}

$('message-list').addEventListener('click', async (event) => {
  const star = event.target.closest('[data-star-id]');
  if (star) {
    event.stopPropagation();
    try {
      await api(`/api/messages/${star.dataset.starId}/star`, { method: 'POST', body: JSON.stringify({ starred: star.dataset.starred !== 'true' }) });
      await loadMessages();
    } catch (error) { toast(error.message); }
    return;
  }
  const row = event.target.closest('[data-id]');
  if (row) openMessage(row.dataset.id);
});

document.querySelectorAll('.nav-item').forEach((button) => button.addEventListener('click', () => {
  document.querySelectorAll('.nav-item').forEach((b) => b.classList.remove('active'));
  button.classList.add('active');
  state.folder = button.dataset.folder;
  state.query = '';
  $('search').value = '';
  $('folder-title').textContent = button.textContent.trim();
  loadMessages();
}));

$('search-form').addEventListener('submit', (event) => { event.preventDefault(); state.query = $('search').value.trim(); loadMessages(); });
$('refresh-button').addEventListener('click', loadMessages);
$('compose-button').addEventListener('click', () => openCompose());
$('close-compose').addEventListener('click', () => $('compose-modal').classList.add('hidden'));
$('back-button').addEventListener('click', renderMessages);
$('reply-button').addEventListener('click', () => {
  if (!state.current) return;
  const address = (state.current.from.match(/<([^>]+)>/) || [null, state.current.from])[1];
  const subject = /^re:/i.test(state.current.subject) ? state.current.subject : `Re: ${state.current.subject}`;
  openCompose({ to: address, subject, body: `\n\n--- Original message ---\n${state.current.text || state.current.snippet}` });
});
$('delete-button').addEventListener('click', async () => {
  if (!state.current) return;
  try { await api(`/api/messages/${state.current.id}/trash`, { method: 'POST', body: '{}' }); toast('Moved to trash'); state.current = null; await loadMessages(); }
  catch (error) { toast(error.message); }
});
$('compose-form').addEventListener('submit', async (event) => {
  event.preventDefault();
  $('send-status').textContent = 'Sending…';
  try {
    await api('/api/messages/send', { method: 'POST', body: JSON.stringify({ to: $('compose-to').value, subject: $('compose-subject').value, body: $('compose-body').value }) });
    $('send-status').textContent = '';
    $('compose-modal').classList.add('hidden');
    toast('Message sent');
    if (state.folder === 'sent') loadMessages();
  } catch (error) { $('send-status').textContent = error.message; }
});
$('logout-button').addEventListener('click', async () => { await api('/api/logout', { method: 'POST', body: '{}' }); location.reload(); });
$('menu-button').addEventListener('click', () => $('sidebar').classList.toggle('open'));

init();
