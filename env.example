<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>ACFO Mail</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="topbar">
    <button class="icon-btn" id="menuBtn" aria-label="Toggle menu">☰</button>
    <div class="brand"><span class="logo">M</span><strong>ACFO Mail</strong></div>
    <label class="search"><span>⌕</span><input id="searchInput" placeholder="Search mail" /></label>
    <button class="avatar" title="Account">AA</button>
  </header>

  <div class="layout">
    <aside class="sidebar" id="sidebar">
      <button class="compose" id="composeBtn">✎ <span>Compose</span></button>
      <nav id="folders">
        <button class="folder active" data-folder="inbox">▣ <span>Inbox</span><b id="unreadCount"></b></button>
        <button class="folder" data-folder="starred">☆ <span>Starred</span></button>
        <button class="folder" data-folder="sent">➤ <span>Sent</span></button>
        <button class="folder" data-folder="trash">♲ <span>Trash</span></button>
      </nav>
      <div class="sync-box">
        <div class="sync-title">Import mail</div>
        <button id="syncGmail">Sync Gmail</button>
        <button id="syncOutlook">Sync Outlook</button>
      </div>
    </aside>

    <main class="content">
      <section class="toolbar">
        <button class="icon-btn" id="refreshBtn" title="Refresh">↻</button>
        <span id="status">Inbox</span>
      </section>
      <section class="mail-list" id="mailList"></section>
      <section class="empty" id="empty" hidden>
        <div class="empty-icon">✉</div>
        <h2>No messages here</h2>
        <p>Incoming mail will appear in this folder.</p>
      </section>
    </main>
  </div>

  <div class="reader-backdrop" id="readerBackdrop" hidden>
    <article class="reader">
      <header><button class="icon-btn" id="closeReader">←</button><h2 id="readerSubject"></h2></header>
      <div class="reader-meta"><strong id="readerFrom"></strong><span id="readerDate"></span></div>
      <div class="reader-to" id="readerTo"></div>
      <div class="reader-body" id="readerBody"></div>
      <footer>
        <button id="readerStar">☆ Star</button>
        <button id="readerTrash">Trash</button>
      </footer>
    </article>
  </div>

  <section class="composer" id="composer" hidden>
    <header><strong>New message</strong><button class="icon-btn" id="closeComposer">×</button></header>
    <input id="composeTo" placeholder="Recipients" />
    <input id="composeCc" placeholder="Cc" />
    <input id="composeSubject" placeholder="Subject" />
    <textarea id="composeBody" placeholder="Write a message"></textarea>
    <footer><button id="sendBtn">Send</button><span id="sendStatus"></span></footer>
  </section>

  <div class="toast" id="toast" hidden></div>
  <script src="/app.js"></script>
</body>
</html>
