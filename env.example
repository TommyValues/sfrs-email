:root{--navy:#0b1f3a;--blue:#2b63b8;--bg:#eef2f6;--surface:#fff;--border:#dce3ec;--text:#172033;--muted:#64748b}*{box-sizing:border-box}html,body{min-height:100%;margin:0}body{font-family:Inter,system-ui,-apple-system,"Segoe UI",sans-serif;color:var(--text);background:var(--bg)}button,input,textarea{font:inherit}.hidden{display:none!important}.login{min-height:100vh;display:grid;place-items:center;padding:24px;background:radial-gradient(circle at 20% 10%,#244e8466,transparent 30%),linear-gradient(145deg,#07162b,var(--navy))}.login-card{width:min(480px,100%);padding:50px;text-align:center;border-radius:26px;background:#fff;box-shadow:0 30px 80px #0005}.seal{width:78px;height:78px;display:grid;place-items:center;margin:auto;color:#fff;font-size:34px;font-weight:800;border-radius:22px;background:linear-gradient(145deg,#3469b4,#112e55)}.eyebrow{margin-top:24px;color:var(--blue);font-size:12px;font-weight:800;letter-spacing:.12em;text-transform:uppercase}.login h1{margin:6px 0;font-size:43px}.login p{color:var(--muted);line-height:1.6}.google-button{min-height:54px;display:flex;align-items:center;justify-content:center;gap:12px;margin:28px 0;color:#fff;font-weight:750;text-decoration:none;border-radius:11px;background:var(--blue);box-shadow:0 12px 25px #2b63b83d}.google-button b{width:27px;height:27px;display:grid;place-items:center;color:#4285f4;border-radius:50%;background:#fff}.warning{color:#b42318!important}.topbar{height:74px;position:sticky;top:0;z-index:20;display:flex;align-items:center;gap:16px;padding:0 24px;color:#fff;background:var(--navy);box-shadow:0 4px 18px #0b1f3a3d}.icon-button,.signout{border:0;color:inherit;background:transparent}.icon-button{width:42px;height:42px;border-radius:10px;font-size:21px}.brand{min-width:190px;display:flex;align-items:center;gap:11px;color:#fff;text-decoration:none}.brand span{width:40px;height:40px;display:grid;place-items:center;color:var(--navy);font-weight:850;border-radius:11px;background:#fff}.search{height:47px;max-width:720px;flex:1;display:flex;align-items:center;gap:10px;padding:0 16px;color:var(--muted);border-radius:12px;background:#f7f9fc}.search input{width:100%;border:0;outline:0;background:transparent}.avatar{width:38px;height:38px;border-radius:50%}.profile{display:flex;flex-direction:column}.profile small{color:#c7d3e4}.signout{padding:9px 13px;border:1px solid #ffffff38;border-radius:8px}.workspace{min-height:calc(100vh - 74px);display:flex}.sidebar{width:250px;display:flex;flex-direction:column;padding:24px 15px;background:#f8fafc;border-right:1px solid var(--border)}.compose{min-height:52px;margin-bottom:22px;color:#fff;font-weight:800;border:0;border-radius:13px;background:var(--blue)}.sidebar nav{display:grid;gap:5px}.nav-item{min-height:45px;display:flex;align-items:center;gap:13px;padding:0 16px;color:#344054;font-weight:650;text-align:left;border:0;border-radius:9px;background:transparent}.nav-item.active{color:var(--blue);background:#eaf2ff}.sidebar footer{margin-top:auto;padding-top:14px;color:#667085;font-size:11px;border-top:1px solid var(--border)}.main{min-width:0;flex:1;padding:23px}.panel{min-height:calc(100vh - 120px);overflow:hidden;border:1px solid var(--border);border-radius:16px;background:#fff;box-shadow:0 6px 24px #0b1f3a0f}.toolbar{min-height:82px;display:flex;align-items:center;justify-content:space-between;padding:17px 25px;border-bottom:1px solid var(--border)}.toolbar small,.reader>small{color:var(--blue);font-weight:800;text-transform:uppercase;letter-spacing:.1em}.toolbar h1{margin:2px 0 0}.row{min-height:64px;display:grid;grid-template-columns:42px minmax(150px,220px) minmax(220px,1fr) 94px;align-items:center;gap:11px;padding:7px 20px;border-bottom:1px solid #edf0f4;cursor:pointer}.row:hover{background:#f8fbff}.row.unread{background:#f1f6ff;font-weight:730}.star{width:36px;height:36px;color:#98a2b3;font-size:22px;border:0;border-radius:50%;background:transparent}.star.on{color:#dfa500}.copy{overflow:hidden;white-space:nowrap;text-overflow:ellipsis}.copy span,time{color:var(--muted);font-weight:400}.row time{text-align:right;font-size:12px}.empty{min-height:360px;display:grid;place-items:center;align-content:center;gap:8px;color:var(--muted);text-align:center}.reader{padding:28px 34px}.reader-actions{display:flex;justify-content:space-between;margin-bottom:30px}.reader-actions button,.reply{padding:9px 15px;color:var(--blue);font-weight:750;border:1px solid #cbd8e9;border-radius:8px;background:#fff}.reader h1{font-size:36px}.meta{display:flex;justify-content:space-between}.meta div div,.meta time{color:var(--muted);font-size:13px}#reader-body{min-height:260px;margin-top:28px;padding-top:24px;border-top:1px solid var(--border)}#reader-body pre{white-space:pre-wrap;line-height:1.7}.frame{width:100%;min-height:520px;border:0}#attachments a{display:inline-block;margin:14px 8px 0 0;padding:9px 13px;color:var(--blue);text-decoration:none;border:1px solid #cbd8e9;border-radius:8px}.reply{margin-top:28px}.modal{position:fixed;inset:0;z-index:100;display:flex;align-items:flex-end;justify-content:flex-end;padding:24px;background:#07162b70}.compose-window{width:min(620px,100%);height:min(650px,88vh);display:flex;flex-direction:column;overflow:hidden;border-radius:16px 16px 8px 8px;background:#fff;box-shadow:0 28px 75px #0005}.compose-window header{display:flex;justify-content:space-between;padding:18px;color:#fff;background:var(--navy)}.compose-window header button{color:#fff;font-size:24px;border:0;background:transparent}.compose-window label{display:flex;gap:12px;padding:15px;border-bottom:1px solid var(--border)}.compose-window label input{flex:1;border:0;outline:0}.compose-window textarea{flex:1;padding:18px;border:0;outline:0;resize:none}.compose-window footer{display:flex;align-items:center;gap:13px;padding:14px;border-top:1px solid var(--border)}.compose-window footer button{padding:11px 22px;color:#fff;border:0;border-radius:8px;background:var(--blue)}.toast{position:fixed;right:23px;bottom:23px;z-index:200;display:none;padding:14px 18px;color:#fff;border-radius:9px;background:#172033}.toast.show{display:block}.sidebar.collapsed{width:78px}.sidebar.collapsed .nav-item span,.sidebar.collapsed .compose span,.sidebar.collapsed footer{display:none}@media(max-width:850px){.profile{display:none}.sidebar{width:78px}.sidebar .nav-item span,.sidebar .compose span,.sidebar footer{display:none}.row{grid-template-columns:38px 150px 1fr}.row time{display:none}}@media(max-width:620px){.topbar{height:auto;flex-wrap:wrap;padding:10px 12px}.brand{min-width:auto}.brand strong,.signout{display:none}.search{order:3;width:100%}.sidebar{width:62px}.main{padding:10px}.row{grid-template-columns:34px 105px 1fr;padding:7px 10px}.modal{padding:0}.compose-window{width:100%;height:92vh;border-radius:16px 16px 0 0}}