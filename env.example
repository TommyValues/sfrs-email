PORT=3000
NODE_ENV=development
APP_EMAIL=contact.acfo.admin@gmail.com
APP_NAME=ACFO Admin
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=replace-with-at-least-32-random-characters
WEBHOOK_SECRET=replace-with-a-long-random-value

# Google Cloud OAuth 2.0 Web application credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional; defaults to APP_BASE_URL/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Optional SMTP fallback (Google Sign-In sends through the Gmail API)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact.acfo.admin@gmail.com
SMTP_PASS=

# Optional Microsoft 365 / Outlook import
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_MAILBOX=
